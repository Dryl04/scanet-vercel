# Database (PostgreSQL)
DATABASE_URL=

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-here-generate-with-openssl-rand-base64-32"
AUTH_SECRET="your-auth-secret-here-same-as-nextauth-secret"

# Email (Resend)
RESEND_API_KEY="re_your_resend_api_key"
EMAIL_FROM="ScaNetwork <noreply@scanetwork.com>"

# App URL (public, used in email templates)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# OpenAI (for business card scanning)
OPENAI_API_KEY="sk-your-openai-api-key"

# Cron secret (for scheduled email processing)
CRON_SECRET="your-cron-secret-here"

# Node environment
NODE_ENV="development"
